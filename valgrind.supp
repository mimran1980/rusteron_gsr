# Known Aeron driver shutdown false positive from Valgrind's view of mapped memory.
{
   aeron_driver_conductor_msync_uninitialised
   Memcheck:Param
   msync(start)
   fun:__syscall_cancel_arch
   fun:__internal_syscall_cancel
   fun:__syscall_cancel
   fun:msync
   fun:aeron_msync
   fun:aeron_driver_conductor_on_close
   ...
}

# Upstream Aeron C shutdown race: conductor idle strategy may read sleeping state
# after context close frees it. This is a real memory-safety pattern, but it is
# outside rusteron's Rust-owned lifecycle control, so it stays suppressed here.
{
   aeron_idle_strategy_sleeping_after_context_close
   Memcheck:Addr8
   fun:aeron_idle_strategy_sleeping_idle
   fun:agent_main
   fun:start_thread
   fun:clone
}

# Aeron client conductor can report "possibly lost" allocations at process exit
# when teardown races with async publication/subscription/image flows.
{
   aeron_client_conductor_image_create_possible
   Memcheck:Leak
   match-leak-kinds: possible
   fun:malloc
   fun:aeron_alloc
   fun:aeron_image_create
   fun:aeron_client_conductor_on_available_image
   fun:aeron_client_conductor_on_driver_response
   fun:aeron_broadcast_receiver_receive
   fun:aeron_client_conductor_do_work
   fun:aeron_do_work
   fun:agent_main
   fun:start_thread
   fun:clone
}

