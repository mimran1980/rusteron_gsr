# Valgrind suppressions for known external/runtime issues.
#
# Keep this file present even when empty so `just test-valgrind` can run.

# Rust test harness retains thread/runtime state until process exit.
{
   rust_test_thread_context_possible_leak
   Memcheck:Leak
   match-leak-kinds: possible
   fun:malloc
   ...
   fun:current_or_unnamed
   fun:_ZN3std4sync4mpmc7context7Context3new*
   ...
   fun:_ZN4test16test_main_static*
}

# Fallback for Rust test runner spawned test-thread bookkeeping that can appear as
# "possibly lost" with toolchain-dependent symbol paths.
{
   rust_test_thread_spawn_possible_leak
   Memcheck:Leak
   match-leak-kinds: possible
   fun:malloc
   ...
   fun:run_test_in_process
   fun:_ZN4test8run_test*
   ...
   fun:call_once<(), dyn core::ops::function::FnOnce<(), Output=()>, alloc::alloc::Global>
   fun:_ZN3std3sys3pal4unix6thread6Thread3new12thread_start*
   fun:start_thread
   fun:clone
}

{
   rust_test_thread_spawn_possible_leak_calloc
   Memcheck:Leak
   match-leak-kinds: possible
   fun:calloc
   ...
   fun:run_test_in_process
   fun:_ZN4test8run_test*
   ...
   fun:call_once<(), dyn core::ops::function::FnOnce<(), Output=()>, alloc::alloc::Global>
   fun:_ZN3std3sys3pal4unix6thread6Thread3new12thread_start*
   fun:start_thread
   fun:clone
}

# Fallback for Rust runtime stack overflow thread metadata retained to process exit.
{
   rust_runtime_stack_overflow_thread_info_reachable
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:malloc
   ...
   fun:*stack_overflow*thread_info*set_current_info*
   ...
   fun:*lang_start_internal*
   fun:main
}

# Exact fallback for toolchains that emit this as an unsuppressed reachable block.
{
   rust_runtime_stack_overflow_thread_info_reachable_exact
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:malloc
   fun:_ZN3std3sys5alloc4unix81_$LT$impl$u20$core..alloc..global..GlobalAlloc$u20$for$u20$std..alloc..System$GT$5alloc*
   fun:_ZN100_$LT$rusteron_archive..test_alloc..TrackingAllocator$u20$as$u20$core..alloc..global..GlobalAlloc$GT$5alloc*
   fun:_RNvCsj4CZ6flxxfE_7___rustc12___rust_alloc
   fun:alloc
   fun:alloc_impl
   fun:allocate
   ...
   fun:_ZN3std3sys3pal4unix14stack_overflow11thread_info16set_current_info*
   fun:init
   fun:init
   fun:init
   fun:{closure#0}
   fun:do_call<std::rt::lang_start_internal::{closure_env#0}, isize>
   fun:catch_unwind<isize, std::rt::lang_start_internal::{closure_env#0}>
   fun:catch_unwind<std::rt::lang_start_internal::{closure_env#0}, isize>
   fun:_ZN3std2rt19lang_start_internal*
   fun:_ZN3std2rt10lang_start*
   fun:main
}

# Fallback for `serial_test` + `scc` lock-map allocations where symbol hashes differ across toolchains.
{
   serial_test_lock_map_generic_malloc
   Memcheck:Leak
   match-leak-kinds: possible,reachable
   fun:malloc
   ...
   fun:_ZN11serial_test9code_lock13check_new_key*
   fun:_ZN11serial_test16serial_code_lock29local_serial_core_with_return*
   ...
   fun:run_test_in_process
}

{
   serial_test_lock_map_generic_calloc
   Memcheck:Leak
   match-leak-kinds: possible,reachable
   fun:calloc
   ...
   fun:_ZN11serial_test9code_lock13check_new_key*
   fun:_ZN11serial_test16serial_code_lock29local_serial_core_with_return*
   ...
   fun:run_test_in_process
}

# Archive replay-merge test can leave an Aeron async publication allocation as reachable
# at process exit under Valgrind. Scope this suppression tightly to that test path.
{
   archive_reply_merge_async_add_publication_reachable
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:malloc
   fun:aeron_alloc
   fun:aeron_client_conductor_async_add_publication
   fun:aeron_async_add_publication
   fun:_ZN16rusteron_archive24AeronAsyncAddPublication3new*
   fun:_ZN16rusteron_archive25ManagedCResource$LT$T$GT$10initialise*
   fun:_ZN16rusteron_archive25ManagedCResource$LT$T$GT$3new*
   fun:_ZN16rusteron_archive24AeronAsyncAddPublication3new*
   fun:_ZN16rusteron_archive5Aeron15add_publication*
   fun:_ZN16rusteron_archive5tests21reply_merge_publisher*
   fun:_ZN16rusteron_archive5tests24test_simple_replay_merge*
}

